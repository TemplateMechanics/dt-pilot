{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://templatemechanics.github.io/dt-pilot/schemas/terraform.schema.json",
  "title": "dt-pilot reflected Terraform-resource catalog",
  "description": "Schema for config/catalog/terraform.json -- the curated list of dynatrace-oss/dynatrace provider resource types that dt-pilot ships scaffolds for under modules/terraform/configs/.",
  "type": "object",
  "required": ["version", "resources"],
  "additionalProperties": true,
  "properties": {
    "$schema":  { "type": "string" },
    "_comment": { "type": "string" },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "resources": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/resource" }
    }
  },
  "$defs": {
    "resource": {
      "type": "object",
      "required": ["resourceType", "family", "displayName", "summary"],
      "additionalProperties": false,
      "properties": {
        "resourceType": {
          "type": "string",
          "pattern": "^dynatrace_[a-z][a-z0-9_]*$",
          "description": "Terraform resource type identifier; must start with 'dynatrace_' (the dynatrace-oss/dynatrace provider's prefix)."
        },
        "family": {
          "type": "string",
          "enum": ["topology", "alerting", "visualization", "automation", "security", "account", "misc"]
        },
        "displayName": { "type": "string" },
        "summary":     { "type": "string" },
        "commonVariables": {
          "type": "array",
          "uniqueItems": true,
          "description": "Variables the generator should pre-declare in the scaffold's variables.tf.example. Each item lists the variable's HCL identifier, type, and a human description.",
          "items": {
            "type": "object",
            "required": ["name", "type", "description"],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9_]{0,62}$"
              },
              "type": {
                "type": "string",
                "description": "HCL type literal (e.g. 'string', 'number', 'bool', 'list(string)')."
              },
              "description": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
