{
  "_comment": "dt-pilot workspace settings — YAML schema associations, formatter defaults, file exclusions. Per-developer overrides belong in your user settings, not here.",
  "files.encoding": "utf8",
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "[yaml]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false
  },
  "[json]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false
  },
  "[powershell]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": true
  },
  "yaml.schemas": {
    "./.vscode/schemas/mcp-servers-catalog.schema.json": [
      ".vscode/mcp.servers.catalog.json"
    ]
  },
  "files.exclude": {
    "**/.monaco": true,
    "**/dryrun": false,
    "**/downloaded": false
  },
  "search.exclude": {
    "**/dryrun/**": true,
    "**/downloaded/**": true,
    "**/.monaco/**": true,
    "**/node_modules/**": true
  }
}
